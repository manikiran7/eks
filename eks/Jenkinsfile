pipeline {
  agent any

  parameters {
    string(name: 'SERVICE_NAME', description: 'Service name to deploy')
    string(name: 'IMAGE_TAG', description: 'Docker image tag to deploy')
  }

  environment {
    AWS_REGION = 'us-east-1'
    PRIVATE_INSTANCE_ID = 'i-0d2bac237c43eb9db'
    GIT_REPO = 'git@github.com:manikiran7/eks.git'
    BASE_DIR = '/opt/deployments'
    REPO_DIR = '/opt/deployments/infra'
    TERRAFORM_DIR = '/opt/deployments/infra/eks'  // ✅ FIXED PATH
  }

  stages {
    stage('Deploy via Private EC2') {
      steps {
        echo "🚀 Starting Terraform deploy for ${params.SERVICE_NAME}:${params.IMAGE_TAG}"

        script {
          def commandId = sh(
            script: """
              aws ssm send-command \
                --instance-ids "${PRIVATE_INSTANCE_ID}" \
                --document-name "AWS-RunShellScript" \
                --region ${AWS_REGION} \
                --comment "Terraform deploy for ${params.SERVICE_NAME}:${params.IMAGE_TAG}" \
                --parameters 'commands=[
                  "set -e",
                  "echo ==== PREPARING REPO DIRECTORY ====",
                  "sudo mkdir -p ${BASE_DIR}",
                  "cd ${BASE_DIR}",
                  "if [ -d ${REPO_DIR} ]; then",
                  "  echo Cleaning existing repo folder...",
                  "  sudo rm -rf ${REPO_DIR}",
                  "fi",
                  "echo ==== CLONING REPOSITORY ====",
                  "sudo git clone ${GIT_REPO} ${REPO_DIR}",
                  "if [ ! -d ${TERRAFORM_DIR} ]; then",
                  "  echo \\\"❌ ERROR: Terraform path not found at ${TERRAFORM_DIR}\\\"",
                  "  echo \\\"Repo structure:\\\"",
                  "  ls -R ${REPO_DIR} || true",
                  "  exit 2",
                  "fi",
                  "cd ${TERRAFORM_DIR}",
                  "echo ==== TERRAFORM INIT ====",
                  "terraform init -input=false",
                  "echo ==== TERRAFORM APPLY ====",
                  "terraform apply -auto-approve -var=\\\"services={\\\\\\\"${params.SERVICE_NAME}\\\\\\\"={image_tag=\\\\\\\"${params.IMAGE_TAG}\\\\\\\",port=8080,replicas=2,path=\\\\\\\"/${params.SERVICE_NAME}\\\\\\\"}}\\\"",
                  "echo ==== ✅ Terraform deployment complete for ${params.SERVICE_NAME}:${params.IMAGE_TAG} ===="
                ]' \
                --query 'Command.CommandId' \
                --output text
            """,
            returnStdout: true
          ).trim()

          echo "🕓 Waiting for Terraform execution (Command ID: ${commandId})"
          sh "aws ssm wait command-executed --command-id ${commandId} --instance-id ${PRIVATE_INSTANCE_ID} --region ${AWS_REGION}"

          echo "📜 Terraform Output:"
          sh """
            aws ssm get-command-invocation \
              --command-id ${commandId} \
              --instance-id ${PRIVATE_INSTANCE_ID} \
              --region ${AWS_REGION} \
              --query 'StandardOutputContent' \
              --output text || true
          """
        }
      }
    }
  }

  post {
    success {
      echo "✅ Terraform deployment succeeded for ${params.SERVICE_NAME}:${params.IMAGE_TAG}"
    }
    failure {
      echo "❌ Terraform deployment failed — check Jenkins logs or SSM output."
    }
  }
}
