pipeline {
  agent any

  parameters {
    string(name: 'SERVICE_NAME', description: 'Service name to deploy')
    string(name: 'IMAGE_TAG', description: 'Docker image tag to deploy')
  }

  environment {
    AWS_REGION = 'us-east-1'
    PRIVATE_INSTANCE_ID = 'i-0d2bac237c43eb9db' // Replace with your private EC2 instance ID
    GIT_REPO = 'git@github.com:manikiran7/eks.git'
    BASE_DIR = '/opt/deployments/infra'
    TERRAFORM_DIR = '/opt/deployments/infra/eks/eks'
  }

  stages {
    stage('Deploy via Private EC2') {
      steps {
        echo "🚀 Starting Terraform deploy for ${params.SERVICE_NAME}:${params.IMAGE_TAG}"

        sh """
          aws ssm send-command \
            --instance-ids "${PRIVATE_INSTANCE_ID}" \
            --document-name "AWS-RunShellScript" \
            --region ${AWS_REGION} \
            --comment "Terraform deploy for ${params.SERVICE_NAME}:${params.IMAGE_TAG}" \
            --parameters 'commands=[
              "set -e",
              "sudo mkdir -p ${BASE_DIR}",
              "cd ${BASE_DIR}",
              "if [ ! -d infra ]; then",
              "  echo Cloning repo first time...",
              "  sudo git clone ${GIT_REPO} infra",
              "else",
              "  echo Pulling latest code...",
              "  cd infra",
              "  sudo git fetch --all --prune",
              "  sudo git reset --hard origin/main",
              "fi",
              "cd ${TERRAFORM_DIR}",
              "echo Running terraform init...",
              "terraform init -input=false",
              "echo Applying Terraform with service ${params.SERVICE_NAME}:${params.IMAGE_TAG}...",
              "terraform apply -auto-approve -var=\\\"services={\\\\\\\"${params.SERVICE_NAME}\\\\\\\"={image_tag=\\\\\\\"${params.IMAGE_TAG}\\\\\\\",port=8080,replicas=2,path=\\\\\\\"/${params.SERVICE_NAME}\\\\\\\"}}\\\"",
              "echo ✅ Terraform deployment complete for ${params.SERVICE_NAME}:${params.IMAGE_TAG}"
            ]'
        """
      }
    }
  }

  post {
    success {
      echo "✅ Terraform applied successfully for ${params.SERVICE_NAME}:${params.IMAGE_TAG}"
    }
    failure {
      echo "❌ Deployment failed. Check SSM Run Command output in AWS Console."
    }
  }
}
